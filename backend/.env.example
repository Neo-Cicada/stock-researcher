# In production, inject these via the host's secret manager / environment
# rather than a committed file — pydantic-settings reads real env vars too, so
# a .env file is a local-dev convenience, not a deployment requirement.

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/kabuka
# Exact allowed frontend origin(s). Set to your real domain in production, e.g.
# ["https://kabuka.example.com"]. Never use ["*"].
CORS_ORIGINS=["http://localhost:3000"]
# Keep false in production: also hides the interactive docs (/docs, /openapi.json).
DEBUG=false
# Free key from https://finnhub.io — powers GET /api/market/themes.
# Optional: without it, Today's Themes falls back to mock data.
FINNHUB_API_KEY=
# Free key from https://fredaccount.stlouisfed.org/apikeys — powers the economic
# calendar (CPI, jobs, GDP, PCE, PPI release dates) on GET /api/market/events.
# Optional: without it, /events falls back to mock (Finnhub's economic calendar
# is premium-gated and 403s on a free key).
FRED_API_KEY=
# SEC EDGAR requires a descriptive User-Agent with contact info on every request
# (https://www.sec.gov/os/webmaster-faq#developers). Powers /api/institutions
# (13F holdings). Put your name + email so SEC can reach you if needed.
SEC_USER_AGENT=Your Name (app-name; you@example.com)
# Per-client API rate limit (slowapi syntax). Default 120/minute.
RATE_LIMIT_DEFAULT=120/minute
# Shared secret for the manual POST /api/reddit/fetch trigger. Leave empty in
# production to disable it; set a random string in dev to use the trigger
# (send it as the X-Admin-Token header).
ADMIN_TOKEN=
