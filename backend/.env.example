DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/kabuka
CORS_ORIGINS=["http://localhost:3000"]
DEBUG=false
# Free key from https://finnhub.io — powers GET /api/market/themes.
# Optional: without it, Today's Themes falls back to mock data.
FINNHUB_API_KEY=
# SEC EDGAR requires a descriptive User-Agent with contact info on every request
# (https://www.sec.gov/os/webmaster-faq#developers). Powers /api/institutions
# (13F holdings). Put your name + email so SEC can reach you if needed.
SEC_USER_AGENT=Your Name (app-name; you@example.com)
